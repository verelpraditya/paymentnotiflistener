# Treat binary files correctly - prevent CRLF conversion
*.jar binary
*.keystore binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.apk binary

# Force LF for text files
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.php text eol=lf
*.sql text eol=lf
gradlew text eol=lf
